---
// 个人页(whois)的链接卡片：左侧图标(slot) + 标题/描述，右侧"打开"外链按钮。
// Projects / Favorite 两组共用，替代之前每张卡片重复粘贴的大段相同 markup。
interface Props {
    title: string;
    description: string;
    href: string;
}
const { title, description, href } = Astro.props
---

<li class="group flex items-center justify-between px-4 py-3 bg-stone-100 dark:bg-stone-600 hover:bg-stone-200 dark:hover:bg-stone-500 outline-none border border-neutral-4 hover:border-neutral-6 rounded-3xl focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-neutral-7 focus-visible:ring-offset-neutral-1">
    <div class="flex flex-row items-stretch gap-5 pl-2">
        <div class="flex items-center justify-center">
            <slot />
        </div>
        <div>
            <span class="transition duration-300 group-hover:translate-x-1 text-neutral-12 text-sm">{title}</span>
            <div class="transition duration-300 group-hover:translate-x-px text-neutral-11 group-hover:text-neutral-11 text-xs">{description}</div>
        </div>
    </div>
    <a type="button" role="button" href={href} target="_blank" aria-label="Open"
       class="inline-flex panda-link items-center justify-center gap-2 outline-none border focus-visible:ring-2 focus-visible:ring-offset-2 bg-stone-100 hover:bg-stone-300 dark:bg-stone-800 dark:hover:bg-stone-600 active:bg-neutral-5 text-neutral-11 border-neutral-6 focus-visible:ring-neutral-8 focus-visible:ring-offset-neutral-1 w-8 h-8 text-base font-medium rounded-xl group/icon">
        <svg fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" aria-label="Open"
             class="transition text-neutral-11 group-hover:text-primary-11 group-focus-visible/icon:text-primary-11"
             width="16" height="16" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 3h6v6"></path>
            <path d="M10 14 21 3"></path>
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        </svg>
    </a>
</li>
